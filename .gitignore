cat > .gitignore <<'EOF'
# =============================================================================
# OS / editor noise
# =============================================================================
.DS_Store
Thumbs.db
*~
*.swp
*.swo

.vscode/
.idea/

# =============================================================================
# ROS / catkin / colcon generated folders
# =============================================================================
build/
devel/
install/
log/
logs/
.catkin_tools/
.catkin_workspace

**/build/
**/devel/
**/install/
**/log/
**/logs/
**/.catkin_tools/

# =============================================================================
# CMake / compiled artifacts
# =============================================================================
CMakeFiles/
CMakeCache.txt
cmake_install.cmake
compile_commands.json

*.o
*.obj
*.so
*.a
*.la
*.lo
*.dll
*.dylib
*.exe
*.out

# =============================================================================
# Python
# =============================================================================
__pycache__/
*.py[cod]
*.pyo
*.pyd
.pytest_cache/
.mypy_cache/
.ipynb_checkpoints/

.venv/
venv/
env/
ENV/

# =============================================================================
# Logs / temporary outputs
# =============================================================================
*.log
*.tmp
*.temp

tmp/
temp/

# =============================================================================
# Large generated experiment / tuning outputs
# =============================================================================
runs/
results/
outputs/
output/
artifacts/
wandb/
mlruns/

# =============================================================================
# ROS bags / databases / recordings
# =============================================================================
*.bag
*.mcap
*.db
*.db-wal
*.sqlite
*.sqlite3

# =============================================================================
# MATLAB / Simulink temporary/generated
# =============================================================================
*.asv
*.m~
slprj/
*.slxc

# =============================================================================
# Archives / installers / big local files
# =============================================================================
*.zip
*.tar
*.tar.gz
*.tgz
*.7z
*.rar
*.iso

EOF
